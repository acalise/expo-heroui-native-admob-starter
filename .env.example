# Copy this file to .env and fill in your values.
# Variables prefixed with EXPO_PUBLIC_ are inlined at build time.

EXPO_PUBLIC_APP_NAME=My App
# EXPO_PUBLIC_API_URL=https://api.yourapp.com

# ── Ads (optional) ────────────────────────────────────────────────────────────
# Set to true to enable Google AdMob. Requires a native build (not Expo Go).
# Replace ad unit IDs in lib/ads.ts with your real IDs before release.
# EXPO_PUBLIC_ADS_ENABLED=false
