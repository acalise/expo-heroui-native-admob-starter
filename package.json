  },
  "bugs": {
    "url": "https://github.com/acalise/expo-heroui-native-admob-starter/issues"
  },
  "keywords": [
    "expo",
    "react-native",
    "heroui",
    "starter-template",
    "typescript",
    "tailwindcss",
    "dark-mode",
    "admob",
    "onboarding",
    "nativewind"
  ],
  "main": "expo-router/entry",
  "scripts": {
